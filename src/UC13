import java.util.*;

// Different palindrome approaches

class PalindromeMethods {

    // Method 1: Two-pointer approach
    public static boolean twoPointer(String input) {
        String str = input.replaceAll("\\s+", "").toLowerCase();

        int left = 0;
        int right = str.length() - 1;

        while (left < right) {
            if (str.charAt(left) != str.charAt(right)) {
                return false;
            }
            left++;
            right--;
        }
        return true;
    }

    // Method 2: StringBuilder reverse
    public static boolean reverseMethod(String input) {
        String str = input.replaceAll("\\s+", "").toLowerCase();

        String reversed = new StringBuilder(str).reverse().toString();
        return str.equals(reversed);
    }

    // Method 3: Stack approach
    public static boolean stackMethod(String input) {
        String str = input.replaceAll("\\s+", "").toLowerCase();

        Stack<Character> stack = new Stack<>();

        for (char c : str.toCharArray()) {
            stack.push(c);
        }

        for (char c : str.toCharArray()) {
            if (c != stack.pop()) {
                return false;
            }
        }
        return true;
    }
}

// Main class
public class UseCase13PalindromeCheckerApp {

    public static void main(String[] args) {
        Scanner scanner = new Scanner(System.in);

        System.out.print("Enter a string: ");
        String input = scanner.nextLine();

        // Measure Two-pointer
        long start1 = System.nanoTime();
        boolean result1 = PalindromeMethods.twoPointer(input);
        long end1 = System.nanoTime();

        // Measure Reverse method
        long start2 = System.nanoTime();
        boolean result2 = PalindromeMethods.reverseMethod(input);
        long end2 = System.nanoTime();

        // Measure Stack method
        long start3 = System.nanoTime();
        boolean result3 = PalindromeMethods.stackMethod(input);
        long end3 = System.nanoTime();

        // Display results
        System.out.println("\n--- Results ---");

        System.out.println("Two Pointer: " + result1 + 
            " | Time: " + (end1 - start1) + " ns");

        System.out.println("Reverse Method: " + result2 + 
            " | Time: " + (end2 - start2) + " ns");

        System.out.println("Stack Method: " + result3 + 
            " | Time: " + (end3 - start3) + " ns");

        scanner.close();
    }
}